// Prisma Schema cho Kho Học Liệu Số (SQLite)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Model User - Người dùng
model User {
  id           String     @id @default(uuid())
  email        String     @unique
  fullName     String
  passwordHash String     @map("password_hash")
  role         String     @default("USER") // ADMIN, USER
  avatarUrl    String?    @map("avatar_url")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Quan hệ
  documents    Document[]
  news         News[]

  @@map("users")
}

// Model Document - Tài liệu
model Document {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Metadata (Dublin Core simplified)
  title       String
  description String?
  author      String?
  subject     String?
  keywords    String   // JSON string array
  language    String   @default("vi")

  // File info
  fileName    String   @map("file_name")
  filePath    String   @map("file_path")
  fileSize    Int?     @map("file_size")
  mimeType    String?  @map("mime_type")

  // Status
  status      String   @default("ACTIVE") // ACTIVE, ARCHIVED, DELETED
  isPublic    Boolean  @default(false) @map("is_public")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Indexes
  @@index([userId])
  @@index([status])
  @@index([isPublic])
  @@map("documents")
}

// Model NewsCategory - Danh mục tin tức
model NewsCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  order       Int      @default(0)
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Quan hệ
  news        News[]

  @@index([status])
  @@index([order])
  @@map("news_categories")
}

// Model News - Tin tức
model News {
  id           String   @id @default(uuid())
  categoryId   String   @map("category_id")
  category     NewsCategory @relation(fields: [categoryId], references: [id])
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Content
  title        String
  slug         String   @unique
  summary      String
  content      String
  thumbnailUrl String?  @map("thumbnail_url")

  // Status
  isPublished  Boolean  @default(false) @map("is_published")
  isFeatured   Boolean  @default(false) @map("is_featured")
  publishedAt  DateTime? @map("published_at")
  viewCount    Int      @default(0) @map("view_count")
  status       String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Indexes
  @@index([categoryId])
  @@index([userId])
  @@index([status])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([publishedAt])
  @@map("news")
}
