# Database
DATABASE_URL="postgresql://admin:password@localhost:5432/learning_repo?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# App
PORT=3001
NODE_ENV=development

# Storage (local path)
UPLOAD_DIR="./uploads"

# MinIO (optional)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="documents"
MINIO_USE_SSL=false
