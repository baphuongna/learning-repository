// Prisma Schema cho Kho Học Liệu Số (SQLite)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Model User - Người dùng
model User {
  id           String     @id @default(uuid())
  email        String     @unique
  fullName     String
  passwordHash String     @map("password_hash")
  role         String     @default("USER") // ADMIN, USER
  avatarUrl    String?    @map("avatar_url")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Quan hệ
  documents    Document[]
  news         News[]
  folders      Folder[]

  @@map("users")
}

// Model Folder - Thư mục tài liệu (Google Drive style)
model Folder {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String?  @default("#3B82F6")
  parentId    String?  @map("parent_id") // null = root folder
  parent      Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[] @relation("FolderTree")
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Status
  status      String   @default("ACTIVE") // ACTIVE, ARCHIVED, DELETED
  isPublic    Boolean  @default(false) @map("is_public")

  // Timestamp
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Quan hệ
  documents   Document[]

  @@index([userId])
  @@index([parentId])
  @@map("folders")
}

// Model Document - Tài liệu
model Document {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folderId     String?  @map("folder_id")
  folder       Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)

  // Metadata
  title        String
  description  String?
  author       String?
  subject      String?
  keywords     String?  // JSON string array

  // File info
  fileName     String?  @map("file_name")
  filePath     String?  @map("file_path")
  fileSize     Int?     @map("file_size")
  mimeType     String?  @map("mime_type")
  inspectionId String?  @map("inspection_id")

  // Status
  status       String   @default("ACTIVE") // ACTIVE, DELETED
  isPublic     Boolean  @default(false) @map("is_public")

  // Timestamps
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([folderId])
  @@index([inspectionId])
  @@index([status])
  @@map("documents")
}

// Model NewsCategory - Danh mục tin tức
model NewsCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  order       Int      @default(0)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  news        News[]

  @@map("news_categories")
}

// Model News - Tin tức
model News {
  id           String        @id @default(uuid())
  categoryId   String        @map("category_id")
  category     NewsCategory  @relation(fields: [categoryId], references: [id])
  userId       String        @map("user_id")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  slug         String        @unique
  summary      String
  content      String
  thumbnailUrl String?       @map("thumbnail_url")
  isPublished  Boolean       @default(false) @map("is_published")
  isFeatured   Boolean       @default(false) @map("is_featured")
  publishedAt  DateTime?     @map("published_at")
  viewCount    Int           @default(0) @map("view_count")
  status       String        @default("DRAFT")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([categoryId, isPublished, publishedAt])
  @@index([userId])
  @@map("news")
}
